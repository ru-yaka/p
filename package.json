		"picocolors": "^1.1.1",
		"yaml": "^2.8.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"@changesets/cli": "^2.29.8",
		"@types/adm-zip": "^0.5.8",
		"@types/bun": "latest",
		"@types/fs-extra": "^11.0.4"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
