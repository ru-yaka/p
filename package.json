	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ru-yaka/p.git"
	},
	"type": "module",
	"bin": {
		"p": "./dist/index.js"
	},
	"scripts": {
		"build": "bun build src/index.ts --outdir dist --target bun && bun run scripts/copy-config.ts",
